# ── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Supabase (required for live SMS + storage) ───────────────────────────────
# Get these from: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── Webhook server ───────────────────────────────────────────────────────────
# Optional: shared secret between your Android app and this server
# Set the same value in your SMS forwarding app's "Custom Header" → X-Secret
WEBHOOK_SECRET=change_me_to_something_random

# Port the webhook server listens on (default 8000)
WEBHOOK_PORT=8000

# ── Fallback (used when Supabase is NOT configured) ──────────────────────────
SMS_DATA_PATH=data/sample_sms.json
